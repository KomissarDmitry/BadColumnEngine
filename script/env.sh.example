#!/usr/bin/env bash
# Переменные окружения для грейдера. Этот файл - аналог env.sh из пункта (c)
# твоей спецификации: его подкладывает грейдер и читает скрипт-обёртка.
#
# BRANCH       - ветка репозитория, которую грейдер клонирует.
# REPO_URL     - URL репозитория (HTTPS).
# INPUT_CSV    - абсолютный путь к hits.csv (вход для convert.sh).
# COLUMNAR     - абсолютный путь, куда convert.sh должен записать поколоночный
#                файл и откуда run_query.sh его читает.
# RESULTS      - директория для логов/результатов грейдера (необязательно
#                использовать в наших скриптах: они пишут результат в stdout,
#                грейдер ловит сам).
export BRANCH="${BRANCH:-main}"
export REPO_URL="${REPO_URL:-https://github.com/example/BadColumnEngine.git}"
export INPUT_CSV="${INPUT_CSV:-/data/hits.csv}"
export COLUMNAR="${COLUMNAR:-/data/hits.bc}"
export RESULTS="${RESULTS:-/data/results}"
